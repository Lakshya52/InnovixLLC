// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id               String          @id @default(cuid())
  email            String          @unique
  name             String?
  password         String
  role             String          @default("USER") // USER or ADMIN
  image            String?
  marketingEmails  Boolean         @default(false)
  transactionalEmails Boolean      @default(true)
  verificationOTP  String?
  otpExpiry        DateTime?
  resetToken       String?
  resetTokenExpiry DateTime?
  lastActive       DateTime        @default(now())
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  orders           Order[]
  keys             ProductKey[]
  tickets          SupportTicket[]
  blogPosts        BlogPost[]
  chatMessages     ChatMessage[]
}

model Order {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  productId   String?
  product     Product?     @relation(fields: [productId], references: [id])
  productName String
  productType String
  amount      Float
  status      String       @default("Processing")
  createdAt   DateTime     @default(now())
  keys        ProductKey[]
}

model Product {
  id          String         @id @default(cuid())
  name        String
  sku         String?
  shortDescription String?
  description String? @db.Text       // Long form paragraph one
  longDescriptionTwo String? @db.Text // Long form paragraph two
  featureHeading String?
  category    String         // OS, Productivity, Enterprise, etc.
  price       Float
  msrp        Float?
  status      String         @default("Live") // Live, Draft, Archive
  iconVariant String?
  image       String? @db.Text
  features    Json?          // Array of strings, stored as JSON for MySQL
  
  // System Requirements
  systemRequirements Json? // Array of { title, minimum, recommended }


  stockKeys   InventoryKey[]
  orders      Order[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model InventoryKey {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  keyValue  String
  isSold    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model InventoryLog {
  id        String   @id @default(cuid())
  type      String   // PRICE_UPDATE, NEW_STOCK, OUT_OF_STOCK
  message   String   @db.Text
  createdAt DateTime @default(now())
}

model ProductKey {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  orderId     String
  order       Order     @relation(fields: [orderId], references: [id])
  name        String
  edition     String?
  keyValue    String
  status      String    @default("Active")
  expiresAt   DateTime?
  iconVariant String?
}

model SupportTicket {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  subject       String
  category      String
  status        String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED
  description   String? @db.Text
  resolution    String? @db.Text
  assignedAgent String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  messages      ChatMessage[]
}

model ChatMessage {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id])
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  senderRole String   // USER or ADMIN
  text      String @db.Text
  createdAt DateTime @default(now())
}

model BlogPost {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  content        String @db.LongText  // Markdown body
  summary        String? @db.Text      // Short summary / elevator pitch
  category       String   // Engineering, Infrastructure, Security, Licensing, etc.
  tags           Json?    // Array of strings, stored as JSON for MySQL
  seoDescription String? @db.Text
  featuredImage  String? @db.Text
  status         String   @default("DRAFT") // PUBLISHED, DRAFT, SCHEDULED
  visibility     String   @default("Public") // Public, Private
  publishDate    DateTime?
  promoted       Boolean  @default(false)
  authorId       String
  author         User     @relation(fields: [authorId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
